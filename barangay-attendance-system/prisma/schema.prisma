generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  role         String
  firstName    String
  middleName   String?
  lastName     String
  age          Int?
  position     String?
  sex          String?
  phone        String?
  photo        String?
  scheduleTime String?  @default("08:00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  records      AttendanceRecord[]
  fingerprints FingerprintTemplate[]
}

model AttendanceRecord {
  recordId  String    @id @default(cuid())
  userId    String
  role      String
  timeIn    DateTime
  timeOut   DateTime?
  breakIn   DateTime?
  breakOut  DateTime?
  dateKey   String
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
}

model Credential {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String
  userId       String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Each user gets 3 fingerprint templates stored during enrollment.
/// templateImage stores the Base64 PNG of the actual fingerprint scan.
model FingerprintTemplate {
  id            String   @id @default(cuid())
  userId        String
  finger        Int      @default(0)
  templateData  String   // Base64 ISO minutiae blob from ZKTeco SDK
  templateImage String?  // Base64 PNG fingerprint scan image
  quality       Int      @default(0)
  source        String   @default("zkteco")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
}

model FingerprintAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  source    String   @default("zkteco")
  finger    Int?
  quality   Int?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
